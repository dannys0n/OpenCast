CS2_GSI_AUTH_TOKEN=replace_this_with_a_secret
CS2_GSI_HOST=127.0.0.1
CS2_GSI_PORT=3000
CS2_GSI_ENABLE_COMMENTARY=1
CS2_GSI_COMMENTARY_ONLY_ON_EVENTS=1
CS2_GSI_COMMENTARY_MIN_INTERVAL=2.0
CS2_GSI_MODEL_TIMEOUT=4.0
MODEL_API_BASE=http://127.0.0.1:12434
